 */
function printAgentInfo(agentConfig) {
    console.log(`
┌─────────────────────────────────────────┐
│  Agent: ${agentConfig.name.padEnd(39)}│
├─────────────────────────────────────────┤
│  描述: ${(agentConfig.description || '').substring(0, 41).padEnd(41)}│
│  技能: ${(agentConfig.skills || '无').padEnd(41)}│
│  模型: ${agentConfig.model.padEnd(41)}│
└─────────────────────────────────────────┘
    `);
