/**
 * 主函数 - 处理命令行参数
 */
function main() {
    const args = process.argv.slice(2);
    
    if (args.length === 0 || args[0] === '--help' || args[0] === '-h') {
        printHelp();
        return;
    }
    
    const agentName = args[0].replace(/^--/, '');
    const task = extractArg(args, ['--task', '-t']) || 'default';
    const scriptPath = extractArg(args, ['--script', '-s']);
    const filePath = extractArg(args, ['--file', '-f']);
    const outputFile = extractArg(args, ['--output', '-o']);
    const verbose = args.includes('--verbose') || args.includes('-v');
    
    try {
        // 加载 Agent 配置
        const agentConfig = loadAgentConfig(agentName);
        
        if (verbose) {
            printAgentInfo(agentConfig);
        }
        
        // 加载项目配置
        const agentStatePath = path.join(CONFIG.projectDir, '.agent-state.json');
        let projectConfig = {};
        let userPreferences = {};
        let contextFiles = [];
        
        if (fs.existsSync(agentStatePath)) {
            const state = JSON.parse(fs.readFileSync(agentStatePath, 'utf-8'));
            projectConfig = state.project_config || {};
            userPreferences = state.user_preferences || {};
            contextFiles = state.context_files || [];
        }
        
        // 构建任务特定数据
        let taskSpecificData = '';
        if (scriptPath) {
            if (fs.existsSync(scriptPath)) {
                const scriptContent = fs.readFileSync(scriptPath, 'utf-8');
                taskSpecificData = `[原始剧本]\n${scriptContent}`;
            } else {
                console.warn(`⚠️ 剧本文件不存在: ${scriptPath}`);
            }
        }
        if (filePath) {
            if (fs.existsSync(filePath)) {
                const fileContent = fs.readFileSync(filePath, 'utf-8');
                taskSpecificData = `[待审核文件]\n${fileContent}`;
            } else {
                console.warn(`⚠️ 文件不存在: ${filePath}`);
            }
        }
        
        // 构建完整 prompt
        const prompt = buildPrompt(agentConfig, task, {
            contextFiles,
            projectConfig,
            userPreferences,
            taskSpecificData
        });
        
        if (verbose) {
            console.log('\n📝 构建的 Prompt 长度:', prompt.length, '字符\n');
        }
        
        // 输出 prompt 或保存文件
        if (outputFile) {
            saveOutput(outputFile, prompt);
        } else {
            // 在 OpenCode 环境中，返回 prompt 供 task 工具使用
            const result = callAgent(prompt);
            
            console.log(`
┌─────────────────────────────────────────┐
│  ✅ Prompt 构建成功                      │
├─────────────────────────────────────────┤
│  Agent: ${agentConfig.name}
│  Task: ${task}
│  Length: ${prompt.length} chars
└─────────────────────────────────────────┘

在 OpenCode 中使用以下方式调用：

task(
    subagent_type="general",
    prompt=\`
${prompt.replace(/`/g, '\\`')}
\`
);

或者使用已封装的快捷命令。
            `);
        }
        
    } catch (error) {
        console.error(`❌ 错误: ${error.message}`);
        process.exit(1);
    }
}

/**
 * 从参数列表提取值
 */
function extractArg(args, keys) {
    for (let i = 0; i < args.length; i++) {
        if (keys.includes(args[i])) {
            return args[i + 1] || '';
        }
    }
    return null;
}

