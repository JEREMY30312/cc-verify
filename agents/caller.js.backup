    const tasks = taskMatch ? parseList(taskMatch[1]) : [];
    
    const outputMatch = content.match(/\[输出规范\]([\s\S]+?)(?=\n\[|\n---)/);
    const outputSpec = outputMatch ? parseList(outputMatch[1]) : [];
    
    const collabMatch = content.match(/\[协作模式\]([\s\S]+?)(?=\n\[|\n---)/);
    const collabMode = collabMatch ? collabMatch[1].trim() : '';
    
    return {
        name: frontMatter.name || agentName,
        description: frontMatter.description || '',
        skills: frontMatter.skills || '',
        model: frontMatter.model || 'opus',
        color: frontMatter.color || 'gray',
        role,
        tasks,
        outputSpec,
        collabMode
    };
}

/**
 * 解析 YAML 片段
 */
function parseYAML(yamlStr) {
    const result = {};
    yamlStr.split('\n').forEach(line => {
        const match = line.match(/^(\s*)(\w+):\s*(.*)$/);
        if (match) {
            const key = match[2];
            const value = match[3].trim();
            result[key] = value || true;
        }
    });
    return result;
}

/**
 * 解析列表项
 */
function parseList(str) {
    return str.split('\n')
        .map(line => line.replace(/^[·\-\*]\s*/, '').trim())
        .filter(line => line.length > 0);
}

/**
 * 读取 context 文件
 */
function loadContextFiles(contextFiles) {
    if (!contextFiles || contextFiles.length === 0) return '';
    
    let context = '';
    contextFiles.forEach(file => {
        const filePath = path.isAbsolute(file) ? file : path.join(CONFIG.projectDir, file);
        if (fs.existsSync(filePath)) {
            const content = fs.readFileSync(filePath, 'utf-8');
            context += `\n\n## ${path.basename(file)}\n${content}`;
        }
    });
    return context;
}

/**
 * 构建完整的 prompt
 */
function buildPrompt(agentConfig, task, options = {}) {
    const {
        contextFiles = [],
        projectConfig = {},
        userPreferences = {},
        taskSpecificData = ''
    } = options;
    
    let prompt = '';
    
    // 角色设定
    prompt += `[角色设定 - ${agentConfig.name}]
${agentConfig.role}

[任务类型]
${task}

`;
    
    // 任务列表
    if (agentConfig.tasks.length > 0) {
        prompt += `[可用任务]
${agentConfig.tasks.map(t => `- ${t}`).join('\n')}

`;
    }
    
    // 项目配置
    prompt += `[项目配置]
- 视觉风格：${projectConfig.visualStyle || '默认'}
- 目标媒介：${projectConfig.targetMedium || '默认'}
- 画幅比例：${projectConfig.aspectRatio || '默认'}
- 集数标识：${projectConfig.episode || '单集'}

`;
    
    // 用户偏好
    if (Object.keys(userPreferences).length > 0) {
        prompt += `[用户偏好]
${JSON.stringify(userPreferences, null, 2)}

`;
    }
    
    // Context 文件
    const contextContent = loadContextFiles(contextFiles);
    if (contextContent) {
        prompt += `[前置产物]
${contextContent}

`;
    }
    
    // 任务特定数据
    if (taskSpecificData) {
        prompt += `[任务数据]
${taskSpecificData}

`;
    }
    
    // 输出规范
    if (agentConfig.outputSpec.length > 0) {
        prompt += `[输出规范]
${agentConfig.outputSpec.map(s => `- ${s}`).join('\n')}

`;
    }
    
    // 协作模式
    if (agentConfig.collabMode) {
        prompt += `[协作模式]
${agentConfig.collabMode}
`;
    }
    
    return prompt;
}

/**
 * 调用 OpenCode API 执行任务
 * 注意：这个函数需要在 OpenCode 环境中运行
 */
function callAgent(prompt) {
    // 在 OpenCode 环境中，使用 task 工具调用 general agent
    // 这里我们返回构建好的 prompt，实际调用由外部处理
    
    return {
        prompt,
        // 这个 prompt 可以在 OpenCode 中使用以下方式调用：
        // task(subagent_type="general", prompt=prompt, ...)
        note: '需要在 OpenCode 环境中使用 task 工具调用'
    };
}

