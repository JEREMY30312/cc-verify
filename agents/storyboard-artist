#!/bin/bash

#===============================================================================
# ANINEO 自定义 Agent 快捷调用脚本
# 
# 封装 agent/caller.js，提供简单的命令行接口
# 
# 使用方式：
#   ./storyboard-artist breakdown --script <path>
#   ./director review --file <path>
#   ./animator motion --script <path>
#===============================================================================

# 获取脚本所在目录
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
CALLER="$SCRIPT_DIR/caller.js"

# 颜色输出
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# 打印帮助
show_help() {
    echo -e "${BLUE}
╔════════════════════════════════════════════════════════════════╗
║  ANINEO Agent 快捷调用脚本                                      ║
╠════════════════════════════════════════════════════════════════╣
║                                                                ║
║  用法:                                                          ║
║    ./storyboard-artist <任务> [选项]                           ║
║    ./director <任务> [选项]                                    ║
║    ./animator <任务> [选项]                                    ║
║                                                                ║
║  通用选项:                                                      ║
║    --script, -s    剧本文件路径                                ║
║    --file, -f      待审核文件路径                              ║
║    --output, -o    输出文件路径                                ║
║    --verbose, -v   详细输出                                    ║
║    --help, -h      显示帮助                                    ║
║                                                                ║
║  示例:                                                          ║
║    ./storyboard-artist breakdown -s script/剧本.md             ║
║    ./director review -f outputs/beat-breakdown-ep01.md         ║
║    ./storyboard-artist beatboard -o beat-board-prompt.md       ║
║                                                                ║
╚════════════════════════════════════════════════════════════════╝${NC}
    "
}

# 检查 caller.js 是否存在
if [ ! -f "$CALLER" ]; then
    echo -e "${RED}❌ 错误: caller.js 不存在${NC}"
    echo "请确保 agents/caller.js 文件存在"
    exit 1
fi

# 分发到对应的 agent
case "$0" in
    *storyboard-artist)
        TASK="${1:-default}"
        shift
        echo -e "${GREEN}🎨 调用 storyboard-artist (分镜师)${NC}"
        node "$CALLER" storyboard-artist --task "$TASK" "$@"
        ;;
    *director)
        TASK="${1:-default}"
        shift
        echo -e "${BLUE}🎬 调用 director (导演)${NC}"
        node "$CALLER" director --task "$TASK" "$@"
        ;;
    *animator)
        TASK="${1:-default}"
        shift
        echo -e "${YELLOW}🎬 调用 animator (动画师)${NC}"
        node "$CALLER" animator --task "$TASK" "$@"
        ;;
    *)
        # 通用模式
        AGENT="$1"
        TASK="${2:-default}"
        shift 2
        
        if [ -z "$AGENT" ]; then
            show_help
            exit 1
        fi
        
        echo -e "调用 Agent: $AGENT, 任务: $TASK"
        node "$CALLER" "$AGENT" --task "$TASK" "$@"
        ;;
esac
